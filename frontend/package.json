  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "cf-typegen": "npx wrangler types",
    "postinstall": "npx wrangler types || true",
    "deploy": "bun run build && bun wrangler deploy --dispatch-namespace chiridion",
    "dev": "react-router dev",
    "preview": "bun run build && vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest",
    "test:e2e": "vitest run e2e/ --config vitest.e2e.config.ts",
    "typecheck": "bun run cf-typegen && react-router typegen && tsc -b",
    "build:desktop": "react-router build"
  },
