generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model AuditLog {
  id             Int           @id @default(autoincrement())
  userId         Int?
  conversationId String?
  modelName      String
  prompt         String
  response       String
  tokensIn       Int           @default(0)
  tokensOut      Int           @default(0)
  latencyMs      Int           @default(0)
  metadata       Json?
  createdAt      DateTime      @default(now())
  Conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  User           User?         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([userId, createdAt])
}

model Chat {
  id             Int                    @id @default(autoincrement())
  userId         Int?
  question       String
  verdict        String
  opinions       Json
  createdAt      DateTime               @default(now())
  cacheHit       Boolean                @default(false)
  conversationId String?
  durationMs     Int?
  tokensUsed     Int?
  embedding      Unsupported("vector")?
  Conversation   Conversation?          @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  User           User?                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model ContextSummary {
  id             Int          @id @default(autoincrement())
  conversationId String
  summary        String
  messageCount   Int          @default(0)
  createdAt      DateTime     @default(now())
  Conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model Conversation {
  id             String           @id
  userId         Int?
  title          String           @default("New Conversation")
  createdAt      DateTime         @default(now())
  updatedAt      DateTime
  isPublic       Boolean          @default(false)
  sessionSummary String?
  AuditLog       AuditLog[]
  Chat           Chat[]
  ContextSummary ContextSummary[]
  User           User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CouncilConfig {
  id            Int             @id @default(autoincrement())
  userId        Int             @unique
  config        Json
  updatedAt     DateTime
  User          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  UserArchetype UserArchetype[]
}

model DailyUsage {
  id        Int      @id @default(autoincrement())
  userId    Int
  date      DateTime @db.Date
  requests  Int      @default(0)
  tokens    Int      @default(0)
  updatedAt DateTime
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model Evaluation {
  id              Int      @id @default(autoincrement())
  sessionId       String
  conversationId  String
  userId          Int
  coherence       Float    @default(0.0)
  consensus       Float    @default(0.0)
  diversity       Float    @default(0.0)
  quality         Float    @default(0.0)
  efficiency      Float    @default(0.0)
  overallScore    Float    @default(0.0)
  recommendations Json?
  strengths       Json?
  weaknesses      Json?
  timestamp       DateTime @default(now())
  User            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([userId, timestamp])
}

model RevokedToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model SemanticCache {
  id        Int                    @id @default(autoincrement())
  createdAt DateTime               @default(now())
  expiresAt DateTime
  keyHash   String                 @unique
  opinions  Json
  prompt    String
  verdict   String
  embedding Unsupported("vector")?
}

model User {
  id                 Int              @id @default(autoincrement())
  email              String?          @unique
  username           String           @unique
  passwordHash       String
  customInstructions String           @default("")
  createdAt          DateTime         @default(now())
  role               String           @default("member")
  AuditLog           AuditLog[]
  Chat               Chat[]
  Conversation       Conversation[]
  CouncilConfig      CouncilConfig?
  CustomProvider     CustomProvider[]
  DailyUsage         DailyUsage[]
  Evaluation         Evaluation[]
  UserArchetype      UserArchetype[]
  UsageLog           UsageLog[]
  Upload             Upload[]
  KnowledgeBase      KnowledgeBase[]
  Memory             Memory[]
  ResearchJob        ResearchJob[]
  Artifact           Artifact[]
  Workflow           Workflow[]
  WorkflowRun        WorkflowRun[]
  Prompt             Prompt[]
  customPersonas     CustomPersona[]
  promptDnas         PromptDNA[]
  memoryBackend      MemoryBackend?
  groupMemberships   GroupMembership[]
}

// ─── Custom Providers (EMOF) ─────────────────────────────────────────────────
model CustomProvider {
  id           Int      @id @default(autoincrement())
  userId       Int
  name         String
  baseUrl      String
  authType     String   // 'bearer' | 'api_key_query' | 'api_key_header' | 'basic' | 'none'
  authKey      String   // AES-256-GCM encrypted
  authHeaderName String? // Custom header name for api_key_header type
  capabilities Json     // { streaming: bool, tools: bool, vision: bool }
  models       String[] // List of model identifiers
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
}

// ─── Usage Logging ───────────────────────────────────────────────────────────
model UsageLog {
  id              Int      @id @default(autoincrement())
  userId          Int
  conversationId  String?
  provider        String
  model           String
  promptTokens    Int      @default(0)
  completionTokens Int     @default(0)
  costUsd         Float    @default(0.0)
  latencyMs       Int      @default(0)
  createdAt       DateTime @default(now())
  User            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([provider, createdAt])
}

model UserArchetype {
  id              Int            @id @default(autoincrement())
  userId          Int
  councilConfigId Int?
  archetypeId     String         @default("")
  name            String
  thinkingStyle   String
  asks            String
  blindSpot       String
  systemPrompt    String
  tools           String[]       @default([])
  icon            String?
  colorBg         String?
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime
  CouncilConfig   CouncilConfig? @relation(fields: [councilConfigId], references: [id], onDelete: Cascade)
  User            User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, archetypeId])
}

// ─── File Uploads (Tier 2) ──────────────────────────────────────────────────
model Upload {
  id            String      @id @default(cuid())
  userId        Int
  filename      String
  originalName  String
  mimeType      String
  sizeBytes     Int
  storagePath   String
  processed     Boolean     @default(false)
  extractedText String?
  metadata      Json?
  createdAt     DateTime    @default(now())
  User          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  KBDocument    KBDocument[]

  @@index([userId, createdAt])
}

// ─── RAG Memory Chunks (Tier 3) ─────────────────────────────────────────────
model Memory {
  id          String                 @id @default(cuid())
  userId      Int
  kbId        String?
  content     String
  chunkIndex  Int                    @default(0)
  sourceName  String?
  sourceUrl   String?
  embedding   Unsupported("vector(1536)")
  createdAt   DateTime               @default(now())
  User        User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  KB          KnowledgeBase?         @relation(fields: [kbId], references: [id], onDelete: Cascade)

  @@index([userId, kbId])
}

// ─── Knowledge Bases (Tier 3) ───────────────────────────────────────────────
model KnowledgeBase {
  id          String       @id @default(cuid())
  userId      Int
  name        String
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  User        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents   KBDocument[]
  memories    Memory[]

  @@unique([userId, name])
}

// ─── KB Documents (Tier 3) ──────────────────────────────────────────────────
model KBDocument {
  id         String         @id @default(cuid())
  kbId       String
  uploadId   String
  filename   String
  chunkCount Int            @default(0)
  indexed    Boolean        @default(false)
  indexedAt  DateTime?
  createdAt  DateTime       @default(now())
  KB         KnowledgeBase  @relation(fields: [kbId], references: [id], onDelete: Cascade)
  Upload     Upload         @relation(fields: [uploadId], references: [id], onDelete: Cascade)
}

// ─── Research Jobs (Tier 4) ─────────────────────────────────────────────────
model ResearchJob {
  id        String   @id @default(cuid())
  userId    Int
  query     String
  status    String   @default("pending") // pending | running | done | failed
  steps     Json     @default("[]")      // ResearchStep[]
  report    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// ─── Artifacts (Tier 4) ─────────────────────────────────────────────────────
model Artifact {
  id             String   @id @default(cuid())
  userId         Int
  conversationId String?
  name           String
  type           String   // code | markdown | html | json | csv
  content        String
  language       String?  // for code: python | javascript | typescript | etc
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  User           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([conversationId])
}

// ─── Workflows (Tier 5) ─────────────────────────────────────────────────────
model Workflow {
  id          String        @id @default(cuid())
  userId      Int
  name        String
  description String?
  definition  Json          // WorkflowDefinition
  version     Int           @default(1)
  published   Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  User        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  runs        WorkflowRun[]

  @@index([userId, createdAt])
}

model WorkflowRun {
  id         String    @id @default(cuid())
  workflowId String
  userId     Int
  status     String    @default("pending") // pending | running | paused | done | failed
  inputs     Json
  outputs    Json?
  error      String?
  startedAt  DateTime  @default(now())
  endedAt    DateTime?
  Workflow   Workflow   @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  User       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workflowId, startedAt])
  @@index([userId, startedAt])
}

// ─── Prompts (Tier 5) ────────────────────────────────────────────────────────
model Prompt {
  id          String          @id @default(cuid())
  userId      Int
  name        String
  description String?
  createdAt   DateTime        @default(now())
  User        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  versions    PromptVersion[]

  @@index([userId, createdAt])
}

model PromptVersion {
  id         String   @id @default(cuid())
  promptId   String
  versionNum Int
  content    String
  model      String?
  temperature Float?
  notes      String?
  createdAt  DateTime @default(now())
  Prompt     Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@unique([promptId, versionNum])
}

// ─── Shared Facts & Personas (Tier 6) ───────────────────────────────────────
model SharedFact {
  id              String   @id @default(cuid())
  conversationId  String
  content         String
  sourceAgent     String
  type            String   // 'fact' | 'decision' | 'assumption' | 'contradiction'
  confidence      Float
  confirmedBy     String[] // agent ids that agreed
  disputedBy      String[] // agent ids that disagreed
  createdAt       DateTime @default(now())

  @@index([conversationId])
}

model CustomPersona {
  id             String   @id @default(cuid())
  userId         Int
  name           String
  systemPrompt   String
  temperature    Float    @default(0.7)
  critiqueStyle  String?
  domain         String?
  aggressiveness Int      @default(5)
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model PromptDNA {
  id             String   @id @default(cuid())
  userId         Int
  name           String
  systemPrompt   String
  steeringRules  String
  consensusBias  String   // 'agree'|'disagree'|'neutral'|'synthesize'
  critiqueStyle  String
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

// ─── Memory Backend (Tier 7) ──────────────────────────────────────────────────
model MemoryBackend {
  id        String   @id @default(cuid())
  userId    Int      @unique
  type      String   // 'local'|'qdrant'|'getzep'|'google_drive'
  config    String   // AES-256-GCM encrypted JSON
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

// ─── RBAC & Groups (Tier 9) ───────────────────────────────────────────────
model UserGroup {
  id        String            @id @default(cuid())
  name      String
  members   GroupMembership[]
  createdAt DateTime          @default(now())
}

model GroupMembership {
  userId  Int
  groupId String
  user    User      @relation(fields: [userId], references: [id])
  group   UserGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([userId, groupId])
}

// ─── Sharing (Tier 9) ────────────────────────────────────────────────────
model SharedConversation {
  id             String    @id @default(cuid())
  conversationId String    @unique
  ownerId        Int
  shareToken     String    @unique @default(cuid())
  access         String    @default("read")
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())
}

model SharedWorkflow {
  id         String    @id @default(cuid())
  workflowId String    @unique
  ownerId    Int
  shareToken String    @unique @default(cuid())
  access     String    @default("read")
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
}

model SharedPrompt {
  id         String    @id @default(cuid())
  promptId   String    @unique
  ownerId    Int
  shareToken String    @unique @default(cuid())
  access     String    @default("read")
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
}

// ─── Marketplace (Tier 10) ──────────────────────────────────────────────────
model MarketplaceItem {
  id          String   @id @default(cuid())
  type        String   // 'prompt'|'workflow'|'persona'|'tool'
  name        String
  description String
  content     Json
  authorId    String
  authorName  String
  tags        String[]
  downloads   Int      @default(0)
  stars       Int      @default(0)
  version     String   @default("1.0.0")
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  reviews     MarketplaceReview[]

  @@index([authorId])
  @@index([type])
}

model MarketplaceReview {
  id        String   @id @default(cuid())
  itemId    String
  userId    String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  item      MarketplaceItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
}

model MarketplaceStar {
  userId String
  itemId String
  @@id([userId, itemId])
}

// ─── Skills Framework (Tier 10) ─────────────────────────────────────────────
model UserSkill {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String
  code        String
  parameters  Json
  createdAt   DateTime @default(now())
  active      Boolean  @default(true)

  @@index([userId])
}

// ─── Traces & Reliability (Tier 11) ─────────────────────────────────────────
model Trace {
  id              String   @id @default(cuid())
  conversationId  String?
  workflowRunId   String?
  userId          Int
  type            String   // 'chat'|'debate'|'workflow'|'research'
  steps           Json     // array of TraceStep objects
  totalLatencyMs  Int
  totalTokens     Int
  totalCostUsd    Float
  createdAt       DateTime @default(now())

  @@index([userId, createdAt])
  @@index([conversationId])
  @@index([type])
}

model ModelReliability {
  model         String   @id
  totalResponses Int     @default(0)
  agreedWith    Int      @default(0)
  contradicted  Int      @default(0)
  toolErrors    Int      @default(0)
  avgConfidence Float    @default(0.0)
  updatedAt     DateTime @updatedAt
}
