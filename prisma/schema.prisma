generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model AuditLog {
  id             Int           @id @default(autoincrement())
  userId         Int?
  conversationId String?
  modelName      String
  prompt         String
  response       String
  tokensIn       Int           @default(0)
  tokensOut      Int           @default(0)
  latencyMs      Int           @default(0)
  metadata       Json?
  createdAt      DateTime      @default(now())
  Conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  User           User?         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([userId, createdAt])
}

model Chat {
  id             Int                    @id @default(autoincrement())
  userId         Int?
  question       String
  verdict        String
  opinions       Json
  createdAt      DateTime               @default(now())
  cacheHit       Boolean                @default(false)
  conversationId String?
  durationMs     Int?
  tokensUsed     Int?
  embedding      Unsupported("vector")?
  Conversation   Conversation?          @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  User           User?                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model ContextSummary {
  id             Int          @id @default(autoincrement())
  conversationId String
  summary        String
  messageCount   Int          @default(0)
  createdAt      DateTime     @default(now())
  Conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model Conversation {
  id             String           @id
  userId         Int?
  title          String           @default("New Conversation")
  createdAt      DateTime         @default(now())
  updatedAt      DateTime
  isPublic       Boolean          @default(false)
  AuditLog       AuditLog[]
  Chat           Chat[]
  ContextSummary ContextSummary[]
  User           User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CouncilConfig {
  id            Int             @id @default(autoincrement())
  userId        Int             @unique
  config        Json
  updatedAt     DateTime
  User          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  UserArchetype UserArchetype[]
}

model DailyUsage {
  id        Int      @id @default(autoincrement())
  userId    Int
  date      DateTime @db.Date
  requests  Int      @default(0)
  tokens    Int      @default(0)
  updatedAt DateTime
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model Evaluation {
  id              Int      @id @default(autoincrement())
  sessionId       String
  conversationId  String
  userId          Int
  coherence       Float    @default(0.0)
  consensus       Float    @default(0.0)
  diversity       Float    @default(0.0)
  quality         Float    @default(0.0)
  efficiency      Float    @default(0.0)
  overallScore    Float    @default(0.0)
  recommendations Json?
  strengths       Json?
  weaknesses      Json?
  timestamp       DateTime @default(now())
  User            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([userId, timestamp])
}

model RevokedToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model SemanticCache {
  id        Int                    @id @default(autoincrement())
  createdAt DateTime               @default(now())
  expiresAt DateTime
  keyHash   String                 @unique
  opinions  Json
  prompt    String
  verdict   String
  embedding Unsupported("vector")?
}

model User {
  id                 Int              @id @default(autoincrement())
  username           String           @unique
  passwordHash       String
  customInstructions String           @default("")
  createdAt          DateTime         @default(now())
  role               String           @default("user")
  AuditLog           AuditLog[]
  Chat               Chat[]
  Conversation       Conversation[]
  CouncilConfig      CouncilConfig?
  CustomProvider     CustomProvider[]
  DailyUsage         DailyUsage[]
  Evaluation         Evaluation[]
  UserArchetype      UserArchetype[]
  UsageLog           UsageLog[]
  Upload             Upload[]
  KnowledgeBase      KnowledgeBase[]
  Memory             Memory[]
  ResearchJob        ResearchJob[]
  Artifact           Artifact[]
}

// ─── Custom Providers (EMOF) ─────────────────────────────────────────────────
model CustomProvider {
  id           Int      @id @default(autoincrement())
  userId       Int
  name         String
  baseUrl      String
  authType     String   // 'bearer' | 'api_key_query' | 'api_key_header' | 'basic' | 'none'
  authKey      String   // AES-256-GCM encrypted
  authHeaderName String? // Custom header name for api_key_header type
  capabilities Json     // { streaming: bool, tools: bool, vision: bool }
  models       String[] // List of model identifiers
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
}

// ─── Usage Logging ───────────────────────────────────────────────────────────
model UsageLog {
  id              Int      @id @default(autoincrement())
  userId          Int
  conversationId  String?
  provider        String
  model           String
  promptTokens    Int      @default(0)
  completionTokens Int     @default(0)
  costUsd         Float    @default(0.0)
  latencyMs       Int      @default(0)
  createdAt       DateTime @default(now())
  User            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([provider, createdAt])
}

model UserArchetype {
  id              Int            @id @default(autoincrement())
  userId          Int
  councilConfigId Int?
  archetypeId     String         @default("")
  name            String
  thinkingStyle   String
  asks            String
  blindSpot       String
  systemPrompt    String
  tools           String[]       @default([])
  icon            String?
  colorBg         String?
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime
  CouncilConfig   CouncilConfig? @relation(fields: [councilConfigId], references: [id], onDelete: Cascade)
  User            User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, archetypeId])
}

// ─── File Uploads (Tier 2) ──────────────────────────────────────────────────
model Upload {
  id            String      @id @default(cuid())
  userId        Int
  filename      String
  originalName  String
  mimeType      String
  sizeBytes     Int
  storagePath   String
  processed     Boolean     @default(false)
  extractedText String?
  metadata      Json?
  createdAt     DateTime    @default(now())
  User          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  KBDocument    KBDocument[]

  @@index([userId, createdAt])
}

// ─── RAG Memory Chunks (Tier 3) ─────────────────────────────────────────────
model Memory {
  id          String                 @id @default(cuid())
  userId      Int
  kbId        String?
  content     String
  chunkIndex  Int                    @default(0)
  sourceName  String?
  sourceUrl   String?
  embedding   Unsupported("vector(1536)")
  createdAt   DateTime               @default(now())
  User        User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  KB          KnowledgeBase?         @relation(fields: [kbId], references: [id], onDelete: Cascade)

  @@index([userId, kbId])
}

// ─── Knowledge Bases (Tier 3) ───────────────────────────────────────────────
model KnowledgeBase {
  id          String       @id @default(cuid())
  userId      Int
  name        String
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  User        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents   KBDocument[]
  memories    Memory[]

  @@unique([userId, name])
}

// ─── KB Documents (Tier 3) ──────────────────────────────────────────────────
model KBDocument {
  id         String         @id @default(cuid())
  kbId       String
  uploadId   String
  filename   String
  chunkCount Int            @default(0)
  indexed    Boolean        @default(false)
  indexedAt  DateTime?
  createdAt  DateTime       @default(now())
  KB         KnowledgeBase  @relation(fields: [kbId], references: [id], onDelete: Cascade)
  Upload     Upload         @relation(fields: [uploadId], references: [id], onDelete: Cascade)
}

// ─── Research Jobs (Tier 4) ─────────────────────────────────────────────────
model ResearchJob {
  id        String   @id @default(cuid())
  userId    Int
  query     String
  status    String   @default("pending") // pending | running | done | failed
  steps     Json     @default("[]")      // ResearchStep[]
  report    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// ─── Artifacts (Tier 4) ─────────────────────────────────────────────────────
model Artifact {
  id             String   @id @default(cuid())
  userId         Int
  conversationId String?
  name           String
  type           String   // code | markdown | html | json | csv
  content        String
  language       String?  // for code: python | javascript | typescript | etc
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  User           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([conversationId])
}
