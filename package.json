{
  "name": "council-project",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "tsx --env-file=.env src/index.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev --prefix frontend\"",
    "build": "npm run build --prefix frontend && tsc && cp -r frontend/dist dist/public",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "test": "vitest run",
    "test:ci": "vitest run --reporter=verbose --bail=1",
    "test:watch": "vitest",
    "benchmark": "tsx tests/benchmarks/benchmarkRunner.ts",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio"
  },
  "keywords": [],
  "author": "Yash Awasthi",
  "license": "ISC",
  "description": "A production-grade multi-model AI orchestration engine with agentic tools and semantic caching.",
  "dependencies": {
    "@octokit/rest": "^21.0.0",
    "@prisma/adapter-pg": "7.5.0",
    "@prisma/client": "7.6.0",
    "@types/multer": "2.1.0",
    "@types/papaparse": "5.5.2",
    "@types/passport": "^1.0.17",
    "@types/passport-github2": "^1.2.9",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "bcryptjs": "3.0.3",
    "bullmq": "^5.0.0",
    "compression": "1.8.1",
    "cors": "2.8.6",
    "crypto-js": "4.2.0",
    "dotenv": "17.3.1",
    "eventsource-parser": "3.0.6",
    "express": "5.2.1",
    "express-rate-limit": "8.3.1",
    "helmet": "8.1.0",
    "ioredis": "5.10.1",
    "isolated-vm": "6.1.2",
    "jsonwebtoken": "9.0.3",
    "lru-cache": "11.0.2",
    "mammoth": "1.12.0",
    "multer": "2.1.1",
    "opossum": "9.0.0",
    "papaparse": "5.5.3",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0",
    "pdf-parse": "2.4.5",
    "pg": "8.20.0",
    "pino": "10.3.1",
    "pino-http": "10.5.0",
    "pino-pretty": "13.1.3",
    "playwright": "1.59.1",
    "rate-limit-redis": "^4.0.0",
    "redis": "5.11.0",
    "socket.io": "4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "xlsx": "0.18.5",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/autocannon": "7.12.7",
    "@types/bcryptjs": "2.4.6",
    "@types/compression": "1.8.1",
    "@types/cors": "2.8.19",
    "@types/crypto-js": "4.2.2",
    "@types/dotenv": "6.1.1",
