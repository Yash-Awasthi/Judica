{
  "name": "council-project",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "tsx --env-file=.env src/index.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev --prefix frontend\"",
    "build": "npm run build --prefix frontend && tsc && cp -r frontend/dist dist/public",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'src/**/*.ts'",
    "test": "vitest run",
    "test:ci": "vitest run --reporter=verbose --bail=1",
    "test:watch": "vitest",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [],
  "author": "Yash Awasthi",
  "license": "ISC",
  "description": "A production-grade multi-model AI orchestration engine with agentic tools and semantic caching.",
  "_dependencyNotes": {
    "redis+ioredis": "Both Redis clients are required: 'redis' is used by src/lib/redis.ts for general caching/pub-sub, 'ioredis' is required by BullMQ (src/queue/connection.ts) and rate-limit-redis (src/middleware/rateLimit.ts).",
    "xlsx": "xlsx 0.18.5 has known CVEs (CVE-2024-22363 and others). It is actively used by src/processors/xlsx.processor.ts. Plan to migrate to 'exceljs' when feasible."
  },
  "dependencies": {
    "@fastify/compress": "^8.0.2",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.0.0",
    "@fastify/express": "^4.0.3",
    "@fastify/helmet": "^13.0.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^9.1.0",
    "@octokit/rest": "^21.0.0",
    "argon2": "^0.41.1",
    "bullmq": "^5.0.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.0",
    "drizzle-orm": "^0.44.0",
    "express": "5.2.1",
    "express-rate-limit": "8.3.1",
    "fastify": "^5.3.0",
    "ioredis": "5.10.1",
    "isolated-vm": "6.1.2",
    "jsonwebtoken": "9.0.3",
    "lru-cache": "11.0.2",
    "mammoth": "1.12.0",
    "opossum": "9.0.0",
    "papaparse": "5.5.3",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0",
    "pdf-parse": "2.4.5",
    "pg": "8.20.0",
    "pino": "10.3.1",
    "pino-http": "10.5.0",
    "prom-client": "^15.1.0",
    "rate-limit-redis": "^4.0.0",
    "redis": "5.11.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "ws": "^8.18.0",
    "xlsx": "0.18.5",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/autocannon": "7.12.7",
    "@types/express": "5.0.6",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "25.5.0",
    "@types/opossum": "8.1.9",
    "@types/papaparse": "^5.5.2",
    "@types/pg": "8.20.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/ws": "^8.5.14",
    "@typescript-eslint/eslint-plugin": "8.57.2",
    "@typescript-eslint/parser": "8.57.2",
    "@vitest/coverage-v8": "^4.1.4",
    "autocannon": "8.0.0",
    "concurrently": "9.2.1",
    "eslint": "10.1.0",
    "globals": "17.4.0",
    "pino-pretty": "13.1.3",
    "playwright": "1.59.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.1.3"
  }
}
