    "@typescript-eslint/eslint-plugin": "8.57.2",
    "@typescript-eslint/parser": "8.57.2",
    "autocannon": "8.0.0",
    "concurrently": "9.2.1",
    "eslint": "10.1.0",
    "globals": "17.4.0",
    "prisma": "7.6.0",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.1.3"
  }
