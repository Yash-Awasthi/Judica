# ── Required ──────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/council
JWT_SECRET=your-jwt-secret-min-16-chars
MASTER_ENCRYPTION_KEY=your-32-char-encryption-key-here-min

# ── Optional (defaults shown) ────────────────────────────
# REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=council_redis_pass
# PORT=3000
# NODE_ENV=development
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=10
# ALLOWED_ORIGINS=http://localhost:3000
# TRUST_PROXY=1
# CURRENT_ENCRYPTION_VERSION=1
# ENABLE_VECTOR_CACHE=false

# ── Docker / Database ──────────────────────────────────────
# POSTGRES_USER=council
# POSTGRES_PASSWORD=councilpass
# POSTGRES_DB=councildb
# GRAFANA_USER=admin
# GRAFANA_PASSWORD=admin

# ── AI Provider Keys (at least one required) ─────────────
# Primary providers — used for default council members
# GOOGLE_API_KEY=AI...                      # Gemini models (gemini-2.5-flash, gemini-2.5-pro)
# OPENAI_API_KEY=sk-proj-...               # OpenAI models (gpt-4o, gpt-4o-mini) — also the catch-all fallback
# ANTHROPIC_API_KEY=sk-ant-...             # Claude models (claude-3-5-sonnet, etc.)

# OpenAI-compatible providers — matched by model name or baseUrl
# GROQ_API_KEY=gsk_...                     # Groq (llama-3.3-70b-versatile, etc.)
# MISTRAL_API_KEY=...                      # Mistral (mistral-small-latest, etc.)
# CEREBRAS_API_KEY=csk-...                 # Cerebras (qwen-3-235b-a22b-instruct-2507, llama3.1-8b)
# OPENROUTER_API_KEY=sk-or-v1-...          # OpenRouter (deepseek/, qwen/, xiaomi/, etc.)
# NVIDIA_API_KEY=nvapi-...                 # NVIDIA NIM (kimi, glm, nemotron, etc.)
# XIAOMI_MIMO_API_KEY=sk-...               # SiliconFlow-hosted Xiaomi MiMo models

# ── Tool Keys (optional) ─────────────────────────────────
# TAVILY_API_KEY=tvly-...                  # Web search tool (used by Empiricist & Historian archetypes)
# SERP_API_KEY=...                         # SerpAPI web search (alternative to Tavily)

# ── Local Model Providers (optional) ─────────────────────
# OLLAMA_BASE_URL=http://localhost:11434   # Ollama local inference server

# ── Additional AI Provider Keys (optional) ───────────────
# COHERE_API_KEY=...                       # Cohere models

# ── Observability (optional) ─────────────────────────────
# LANGFUSE_SECRET_KEY=sk-lf-...           # Langfuse tracing secret key
# LANGFUSE_PUBLIC_KEY=pk-lf-...           # Langfuse tracing public key

# ── Custom System Prompt (optional) ──────────────────────
# SYSTEM_PROMPT="You are a helpful assistant."