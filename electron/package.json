{
  "name": "molecule",
  "version": "0.1.0",
  "description": "Multi-AI deliberation desktop app",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:electron\"",
    "dev:frontend": "cd ../frontend && bun run dev",
    "dev:electron": "tsc -p tsconfig.json && electron .",
    "build": "npm run build:frontend && npm run build:electron",
    "build:frontend": "cd ../frontend && bun run build",
    "build:electron": "tsc -p tsconfig.json",
    "dist": "npm run build && electron-builder",
    "dist:all": "npm run build && electron-builder --mac --win --linux"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^20.0.0",
    "concurrently": "^8.2.0",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "typescript": "^5.4.0"
  },
  "build": {
    "appId": "com.molecule.app",
    "productName": "Molecule",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "../frontend/build/client/**/*"
    ],
    "extraResources": [
      {
        "from": "../frontend/build/client",
        "to": "ui"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": ["dmg", "zip"]
    },
    "win": {
      "target": ["nsis", "portable"]
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Office"
    }
  }
}
