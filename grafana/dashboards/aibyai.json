          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "stacking": { "mode": "normal" }
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(provider_tokens_total[5m])) by (model)",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ]
    }
